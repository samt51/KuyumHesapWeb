@using KuyumHesapWeb.Core.Feature.StockFeature.Queries.GetAll
@model List<GetAllStockQueryResponse>
@{
    ViewData["Title"] = "Index";
    var noLayout = Context.Request.Query["noLayout"] == "1";
    Layout = noLayout ? "~/Views/Shared/_IframeLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
}


@section Styles {
    <link rel="stylesheet" href="~/css/stoklar_index.css" />
}
<div class="flex flex-col md:flex-row gap-4 w-full h-[calc(100vh-1.5rem)]">

    <!-- SOL TARAF: FORM PANELİ -->
    <div class="flex flex-col flex-[3]">
        <div class="panel bg-white rounded-lg shadow-sm border border-rolex-green p-4 flex flex-col flex-grow min-h-0">
            <h2 class="text-lg font-semibold text-gray-800 mb-4 pb-2 border-b border-rolex-green flex-shrink-0">Stok Tanımlama</h2>
            <div class="flex-grow overflow-y-auto pr-3 -mr-3">
                <form id="item-form" class="grid grid-cols-1 md:grid-cols-2 gap-x-4 gap-y-4 mt-2">
                    <input type="hidden" id="stokID">

                    <div class="relative form-group md:col-span-2">
                        <input type="text" id="stokAdi" required class="form-input text-sm mt-1 block w-full p-2 border border-rolex-green rounded-md shadow-sm focus:border-black focus:ring-0 peer" placeholder=" ">
                        <label for="stokAdi" class="form-label">Stok Adı</label>
                    </div>

                    <div class="relative form-group">
                        <select id="stokTipID" required class="form-input text-sm mt-1 block w-full p-2 border border-rolex-green rounded-md shadow-sm focus:border-black focus:ring-0">
                            <option value="" disabled selected>Stok Tipi Seçiniz</option>
                        </select>
                        <label for="stokTipID" class="form-label">Stok Tipi</label>
                    </div>

                    <div class="relative form-group">
                        <input type="text" id="grupAdi" class="form-input text-sm mt-1 block w-full p-2 border border-gray-300 bg-gray-100 rounded-md shadow-sm peer" placeholder=" " readonly>
                        <label for="grupAdi" class="form-label">Stok Grubu (Otomatik)</label>
                        <input type="hidden" id="grupID">
                    </div>

                    <div class="relative form-group">
                        <select id="birim" required class="form-input text-sm mt-1 block w-full p-2 border border-rolex-green rounded-md shadow-sm focus:border-black focus:ring-0">
                            <option value="" disabled selected>Birim Seçiniz</option>
                            <option value="Gram">Gram</option>
                            <option value="Adet">Adet</option>
                            <option value="Carat">Carat</option>
                        </select>
                        <label for="birim" class="form-label">Birim</label>
                    </div>

                    <div class="relative form-group">
                        <input type="text" id="stokBirimiAdi" class="form-input text-sm mt-1 block w-full p-2 border border-gray-300 bg-gray-100 rounded-md shadow-sm peer" placeholder=" " readonly>
                        <label for="stokBirimiAdi" class="form-label">Stok Birimi (Otomatik)</label>
                        <input type="hidden" id="stokBirimi">
                    </div>

                    <div class="relative form-group">
                        <select id="iscilikBirimi" required class="form-input text-sm mt-1 block w-full p-2 border border-rolex-green rounded-md shadow-sm focus:border-black focus:ring-0">
                            <option value="" disabled selected>İşçilik Birimi Seçiniz</option>
                        </select>
                        <label for="iscilikBirimi" class="form-label">İşçilik Birimi</label>
                    </div>

                    <div class="relative form-group">
                        <input type="text" id="milyem" required class="form-input text-sm mt-1 block w-full p-2 border border-rolex-green rounded-md shadow-sm focus:border-black focus:ring-0 peer" placeholder=" ">
                        <label for="milyem" class="form-label">Milyem</label>
                    </div>

                    <div class="border border-rolex-green rounded-md p-2 flex items-center justify-between md:col-span-2">
                        <span class="text-xs font-medium text-gray-700">Aktif</span>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="aktif" class="sr-only peer" checked>
                            <div class="w-9 h-5 bg-gray-200 rounded-full peer peer-focus:ring-2 peer-focus:ring-rolex-green peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-rolex-green"></div>
                        </label>
                    </div>

                </form>
            </div>
            <div class="flex justify-end gap-3 pt-4 mt-auto border-t border-gray-200 flex-shrink-0">
                <div id="add-mode-buttons" class="flex gap-x-3">
                    <button type="button" id="vazgec-btn" class="px-6 py-1.5 bg-secondary text-white text-sm font-semibold rounded-md hover:bg-opacity-90 shadow-sm">VAZGEÇ</button>
                    <button type="submit" form="item-form" class="px-6 py-1.5 bg-success text-white text-sm font-semibold rounded-md hover:bg-opacity-90 shadow-sm">EKLE</button>
                </div>
                <div id="edit-mode-buttons" class="hidden flex gap-x-3">
                  
                    <button type="button" id="vazgec-guncelle-btn" class="px-6 py-1.5 bg-secondary text-white text-sm font-semibold rounded-md hover:bg-opacity-90 shadow-sm">VAZGEÇ</button>
                    <button type="submit" form="item-form" class="px-6 py-1.5 bg-rolex-green text-white text-sm font-semibold rounded-md hover:bg-opacity-90 shadow-sm">GÜNCELLE</button>
                </div>
            </div>
        </div>
    </div>

    <!-- SAĞ TARAF: LİSTE PANELİ -->
    <div class="flex flex-col flex-[2]">
        <div class="panel bg-white rounded-lg shadow-sm border border-rolex-green p-3 flex flex-col flex-grow min-h-0">
            <div class="flex justify-between items-center mb-3">
                <h2 class="text-lg font-semibold text-gray-800 flex-shrink-0">Stok Listesi</h2>
                <div class="flex items-center gap-2">
                    <input type="text" id="listSearchInput" placeholder="Stok Adı Ara..." class="form-input text-xs w-28 p-1.5 border border-rolex-green rounded-md shadow-sm focus:border-rolex-green focus:ring-rolex-green focus:ring-opacity-50">
                    <select id="grupFilterSelect" class="form-input text-xs w-28 p-1.5 border border-rolex-green rounded-md shadow-sm focus:border-rolex-green focus:ring-rolex-green focus:ring-opacity-50">
                        <option value="">Tüm Gruplar</option>
                    </select>
                    <select id="tipFilterSelect" class="form-input text-xs w-28 p-1.5 border border-rolex-green rounded-md shadow-sm focus:border-rolex-green focus:ring-rolex-green focus:ring-opacity-50">
                        <option value="">Tüm Tipler</option>
                    </select>
                </div>
            </div>
            <div class="flex-grow overflow-y-auto">
                <div class="flex justify-between items-center text-xs font-semibold text-gray-500 px-2 py-1.5 border-b sticky top-0 bg-white z-10">
                    <span>Stok Adı</span>
                    <div class="flex items-center gap-x-6 text-center">
                        <span class="w-10">Birim</span>
                        <span class="w-12">İşçilik</span>
                        <span class="w-12">Milyem</span>
                        <span class="w-8">Durum</span>
                    </div>
                </div>
                <div id="item-list" class="space-y-1"></div>
            </div>
        </div>
    </div>
</div>

<!-- Silme Onay Modalı -->
<div id="delete-modal" class="fixed inset-0 bg-gray-900 bg-opacity-50 flex items-center justify-center hidden z-50 transition-opacity duration-300">
    <div class="bg-white rounded-lg shadow-xl p-4 w-full max-w-xs transform transition-all duration-300 scale-95">
        <h3 class="text-base font-semibold text-gray-800">Kaydı Sil</h3>
        <p class="mt-2 text-xs text-gray-600">Bu kaydı silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.</p>
        <div id="modal-item-name" class="mt-2 font-bold text-rolex-green text-sm"></div>
        <div class="mt-4 flex justify-end gap-3">
            <button id="cancel-delete-btn" class="px-4 py-1.5 bg-secondary text-white text-sm font-semibold rounded-md hover:bg-opacity-90 shadow-sm">İptal</button>
            <button id="confirm-delete-btn" class="px-4 py-1.5 bg-danger text-white text-sm font-semibold rounded-md hover:bg-opacity-90 shadow-sm">Sil</button>
        </div>
    </div>
</div>

<div id="toast-container" class="fixed bottom-4 right-4 z-50"></div>
<script src="~/js/stoklar_index.js" asp-append-version="true"></script>


