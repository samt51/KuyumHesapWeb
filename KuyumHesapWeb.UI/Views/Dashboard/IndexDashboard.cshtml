@using KuyumHesapWeb.Core.Feature.DashboardFeature.Queries.GetAllDashboard
@model GetAllDashboardQueryResponse
@{
    ViewData["Title"] = "Index";
    var noLayout = Context.Request.Query["noLayout"].ToString() == "1";
    Layout = noLayout ? "~/Views/Shared/_IframeLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
    <link rel="stylesheet" href="~/css/home_dashboard.css" asp-append-version="true" />
}
<div class="p-6 flex-1 overflow-y-auto min-h-0 min-w-0">
    <p id="welcome-text" class="text-base font-semibold text-gray-600"></p>

    <div class="mt-6 flex flex-wrap gap-5">
        <div id="kasalar-card"
             class="bg-white rounded-xl shadow-md border-t-4 border-green-500 cursor-pointer hover:shadow-lg transition-shadow"
             style="width: 320px;">
            <div class="flex items-center justify-between px-5 pt-4 pb-2">
                <div>
                    <h2 class="text-sm font-bold text-gray-700 uppercase tracking-wide">Kasalar</h2>
                    <p class="text-xs text-gray-400 mt-0.5">Nakit Toplam (HAS)</p>
                </div>
                <i class="fas fa-wallet text-xl text-green-500"></i>
            </div>
            <div class="px-5 pb-4">
                <div id="kasalar-ozet" class="flex items-end gap-2 mt-1">
                    <i class="fas fa-spinner fa-spin text-gray-300 text-xl"></i>
                </div>
                <p class="text-xs text-gray-400 mt-3">Detaylar için tıklayın →</p>
            </div>
        </div>
    </div>
</div>

<!-- Modal ve toastlar (aynı) -->
<div id="kasalar-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="absolute inset-0 bg-black bg-opacity-50" id="kasalar-modal-bg"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 z-10 overflow-hidden">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <div class="flex items-center gap-3">
                <i class="fas fa-wallet text-green-500 text-xl"></i>
                <h3 class="font-bold text-gray-800 text-lg">Kasa Detayları</h3>
            </div>
            <button id="kasalar-modal-close" class="text-gray-400 hover:text-gray-700 text-2xl leading-none">&times;</button>
        </div>
        <div id="kasalar-modal-body" class="p-6 space-y-3 max-h-96 overflow-y-auto">
            <div class="flex items-center justify-center py-8">
                <i class="fas fa-spinner fa-spin text-gray-300 text-3xl"></i>
            </div>
        </div>
    </div>
</div>

<div id="toast-container" class="fixed top-5 right-5 z-50 flex flex-col items-end gap-2"></div>

<!-- removed left-0 and w-full; positioning handled by CSS var and JS -->
<div class="scrolling-ticker-bar fixed bottom-0 bg-[var(--scrolling-ticker-bg)] text-[var(--scrolling-ticker-text)] shadow-[0_-2px_5px_rgba(0,0,0,0.2)] z-50 flex items-center">
    <div class="flex-grow overflow-hidden whitespace-nowrap scrolling-ticker-container py-2.5">
        <div class="scrolling-ticker-content" id="tickerContent">
            <!-- JS ile doldurulacak -->
        </div>
    </div>
    <button id="refresh-rates-btn" class="flex-shrink-0 px-4 py-2.5 h-full text-white hover:bg-gray-600 transition-colors duration-200" title="Kurları Güncelle">
        <i class="fas fa-sync-alt"></i>
    </button>
</div>
@section Scripts {
    <script>
        window.CURE_GET_LATEST_URL = '@Url.Action("GetLatestCure", "Cure")';
    </script>

    <script src="~/js/home_dashboard.js" asp-append-version="true"></script>
}