@using KuyumHesapWeb.Core.Feature.UserFeature.Commands.Create
@model CreateUserCommandRequest
@{
    ViewData["Title"] = "Kullanıcı Tanımlama";
    var noLayout = Context.Request.Query["noLayout"].ToString() == "1";
    Layout = noLayout ? "~/Views/Shared/_IframeLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        .form-group .form-label {
            position: absolute;
            top: 0.5rem;
            left: 0.6rem;
            color: #6b7280;
            pointer-events: none;
            transition: all 0.2s ease-in-out;
            background-color: white;
            padding: 0 0.25rem;
            font-size: 0.875rem;
        }

        .form-group .form-input:focus + .form-label,
        .form-group .form-input:not(:placeholder-shown) + .form-label {
            top: -0.6rem;
            left: 0.5rem;
            font-size: 0.75rem;
            color: #1f2937;
        }
    </style>
}

<div class="flex flex-col md:flex-row gap-4 w-full h-[calc(100vh-1.5rem)] @(noLayout ? "p-3" : "")">
    <div class="flex flex-col flex-1">
        <div class="panel bg-white rounded-lg shadow-sm border border-rolex-green p-4 flex flex-col flex-grow min-h-0">
            <h2 class="text-lg font-semibold text-gray-800 mb-4 pb-2 border-b border-rolex-green flex-shrink-0">Kullanıcı Tanımlama</h2>
            <div class="flex-grow overflow-y-auto pr-3 -mr-3">
                <form asp-controller="User" asp-action="Create" id="kullanici-form" class="space-y-4">
                    @Html.AntiForgeryToken()
                    <div class="relative form-group">
                        <input type="text" asp-for="Email" id="kullanici-adi" required class="form-input text-sm mt-1 block w-full p-2 border border-rolex-green rounded-md shadow-sm peer" placeholder=" ">
                        <label for="kullanici-adi" class="form-label">Email</label>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="relative form-group">
                            <input type="password" id="sifre" asp-for="Password" class="form-input text-sm mt-1 block w-full p-2 pr-10 border border-rolex-green rounded-md shadow-sm peer" placeholder=" ">
                            <label for="sifre" class="form-label">Şifre</label>
                        </div>
                        <div class="relative form-group">
                            <input type="password" id="sifre-tekrar" class="form-input text-sm mt-1 block w-full p-2 pr-10 border border-rolex-green rounded-md shadow-sm peer" placeholder=" ">
                            <label for="sifre-tekrar" class="form-label">Şifre Tekrar</label>
                            <span id="sifre-uyari" class="hidden text-xs text-danger mt-1">Şifreler uyuşmuyor.</span>
                        </div>
                    </div>

                    <div class="relative form-group">
                        <input type="tel" id="telefon" asp-for="Phone" class="form-input text-sm mt-1 block w-full p-2 border border-rolex-green rounded-md shadow-sm peer" placeholder=" ">
                        <label for="telefon" class="form-label">Telefon</label>
                    </div>

                    <div class="relative form-group">
                        <input type="text" id="barkod-yazici-adi" asp-for="BarkodYaziciAdi" class="form-input text-sm mt-1 block w-full p-2 border border-rolex-green rounded-md shadow-sm peer" placeholder=" ">
                        <label for="barkod-yazici-adi" class="form-label">Barkod Yazıcı Adı</label>
                    </div>

                    <div class="relative form-group">
                        <input type="text" id="fis-yazici-adi" asp-for="FisYaziciAdi" class="form-input text-sm mt-1 block w-full p-2 border border-rolex-green rounded-md shadow-sm peer" placeholder=" ">
                        <label for="fis-yazici-adi" class="form-label">Fiş Yazıcı Adı</label>
                    </div>

                    <div class="relative form-group">
                        <input type="text" id="varsayilan-yazici-adi" asp-for="VarsayilanYaziciAdi" class="form-input text-sm mt-1 block w-full p-2 border border-rolex-green rounded-md shadow-sm peer" placeholder=" ">
                        <label for="varsayilan-yazici-adi" class="form-label">Varsayılan Yazıcı Adı</label>
                    </div>

                    <div class="border border-rolex-green rounded-md p-2 flex items-center justify-between">
                        <span class="text-xs font-medium text-gray-700">Aktif</span>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" asp-for="Active" id="aktif-checkbox" class="sr-only peer" checked>
                            <div class="w-9 h-5 bg-gray-200 rounded-full peer peer-focus:ring-2 peer-focus:ring-rolex-green peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-rolex-green"></div>
                        </label>
                    </div>
                    
                    <div class="flex justify-end gap-3 pt-4 border-t border-gray-200">
                        <button type="submit" class="px-8 py-2 bg-rolex-green text-white text-sm font-semibold rounded-md hover:bg-opacity-90 shadow-md">KAYDET</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="toast-container" class="fixed bottom-4 right-4 z-50"></div>

@section Scripts {
    <script>
        // Sifre kontrolü vs eklenebilir
    </script>
}

