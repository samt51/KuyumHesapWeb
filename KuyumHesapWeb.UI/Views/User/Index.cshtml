@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
    var noLayout = Context.Request.Query["noLayout"].ToString() == "1";
    Layout = noLayout ? "~/Views/Shared/_IframeLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/user_index.css" asp-append-version="true" />
}

<div class="h-screen flex flex-col bg-slate-50 overflow-hidden font-sans">
    <!-- Top Header Bar -->
    <div class="flex-shrink-0 bg-white border-b border-gray-200 px-6 py-3 flex justify-between items-center shadow-sm relative z-20">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-rolex-green/10 rounded-xl flex items-center justify-center text-rolex-green">
                <i class="fas fa-user-shield text-xl"></i>
            </div>
            <div class="hidden sm:block">
                <h1 class="text-lg font-bold text-gray-800 leading-tight">Sistem Kullanıcıları</h1>
                <p class="text-[10px] text-gray-500 font-medium uppercase tracking-wider">Yönetim / Güvenlik Ayarları</p>
            </div>
        </div>
        <div class="flex items-center gap-2">
            <span id="list-count" class="bg-gray-100 text-gray-600 px-3 py-1 rounded-full text-[11px] font-bold border border-gray-200">0 Kayıt</span>
        </div>
    </div>

    <!-- Main Content Area: Responsive Stack -->
    <div class="flex-1 overflow-y-auto lg:overflow-hidden p-3 sm:p-4 min-h-0 bg-slate-50 custom-scrollbar">
        <div class="flex flex-col lg:flex-row gap-4 h-full">
            
            <!-- Left: Form Section -->
            <div class="lg:flex-[1.5] bg-white border border-gray-200 rounded-2xl shadow-sm flex flex-col min-h-[500px] lg:min-h-0 overflow-hidden">
                <div class="p-6 sm:p-8 flex-1 overflow-y-auto custom-scrollbar">
                    <div class="mb-6">
                        <h3 id="form-title" class="text-sm font-bold text-gray-900 mb-1">Yeni Kullanıcı Bilgileri</h3>
                        <p id="form-desc" class="text-[10px] sm:text-xs text-gray-500">Sisteme yeni bir kullanıcı ekleyin veya seçilen kullanıcıyı güncelleyin.</p>
                    </div>

                    <form id="user-form" class="space-y-6">
                        <input type="hidden" id="userID">

                        <div class="relative form-group group">
                            <input type="email" id="email" required autocomplete="off" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                            <label for="email" class="form-label">E-Posta Adresi</label>
                        </div>

                        <div class="relative form-group group">
                            <input type="password" id="password" autocomplete="new-password" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                            <label for="password" class="form-label">Şifre (Boş bırakılırsa değişmez)</label>
                        </div>

                        <div class="relative form-group group">
                            <select id="roleID" required class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none">
                                <option value="" disabled selected>Rol Seçiniz</option>
                            </select>
                            <label for="roleID" class="form-label">Kullanıcı Rolü</label>
                        </div>

                        <div class="relative form-group group">
                            <input type="tel" id="phone" autocomplete="off" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                            <label for="phone" class="form-label">Telefon Numarası</label>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div class="relative form-group group">
                                <input type="text" id="barkodYaziciAdi" autocomplete="off" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                                <label for="barkodYaziciAdi" class="form-label text-[10px]">Barkod Yazıcı</label>
                            </div>
                            <div class="relative form-group group">
                                <input type="text" id="fisYaziciAdi" autocomplete="off" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                                <label for="fisYaziciAdi" class="form-label text-[10px]">Fiş Yazıcı</label>
                            </div>
                        </div>

                        <div class="relative form-group group">
                            <input type="text" id="varsayilanYaziciAdi" autocomplete="off" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                            <label for="varsayilanYaziciAdi" class="form-label">Varsayılan Yazıcı</label>
                        </div>

                        <div class="flex items-center justify-between p-4 bg-gray-50 rounded-2xl border border-gray-100">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-xl bg-white flex items-center justify-center text-rolex-green shadow-sm">
                                    <i class="fas fa-toggle-on text-sm"></i>
                                </div>
                                <span class="text-xs font-bold text-gray-700">Hesap Durumu (Aktif)</span>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" id="active" class="sr-only peer" checked>
                                <div class="w-11 h-6 bg-gray-200 rounded-full peer peer-focus:ring-2 peer-focus:ring-rolex-green/20 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-rolex-green"></div>
                            </label>
                        </div>
                    </form>
                </div>

                <!-- Bottom Actions -->
                <div class="p-4 sm:p-6 border-t border-gray-100 bg-gray-50/50 rounded-b-2xl">
                    <div id="add-mode-buttons" class="flex justify-end gap-2">
                        <button type="button" id="vazgec-btn" class="px-4 sm:px-8 py-2.5 bg-white border border-gray-200 text-gray-600 text-[10px] sm:text-xs font-bold rounded-xl hover:bg-gray-100 transition-all active:scale-[0.98]">
                            TEMİZLE
                        </button>
                        <button type="submit" form="user-form" class="px-6 sm:px-10 py-2.5 bg-rolex-green text-white text-[10px] sm:text-xs font-bold rounded-xl hover:bg-opacity-90 hover:shadow-lg hover:shadow-rolex-green/20 transition-all active:scale-[0.98] flex items-center justify-center gap-2">
                            <i class="fas fa-user-plus"></i>
                            <span>KAYDET</span>
                        </button>
                    </div>

                    <div id="edit-mode-buttons" class="hidden flex justify-end gap-2">
                        <button type="button" id="vazgec-guncelle-btn" class="px-4 py-2.5 bg-white border border-gray-200 text-gray-600 text-[10px] sm:text-xs font-bold rounded-xl hover:bg-gray-100 transition-all active:scale-[0.98]">
                            VAZGEÇ
                        </button>
                        <button type="submit" form="user-form" class="px-6 sm:px-10 py-2.5 bg-rolex-green text-white text-[10px] sm:text-xs font-bold rounded-xl hover:bg-opacity-90 hover:shadow-lg hover:shadow-rolex-green/20 transition-all active:scale-[0.98] flex items-center justify-center gap-2">
                            <i class="fas fa-save text-sm"></i>
                            <span>GÜNCELLE</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Right: List Section -->
            <div class="lg:flex-[2.5] bg-white border border-gray-200 rounded-2xl flex flex-col min-h-[400px] lg:min-h-0 shadow-sm relative overflow-hidden">
                <!-- List Header -->
                <div class="p-4 sm:p-6 border-b border-gray-100 space-y-4">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                        <h3 class="text-sm font-bold text-gray-900">Kullanıcı Listesi</h3>
                        <div class="flex gap-2">
                            <div class="relative w-full sm:w-64">
                                <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-[10px]"></i>
                                <input type="text" id="user-search" placeholder="E-Posta ile ara..." class="w-full pl-8 pr-3 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-rolex-green/10 focus:border-rolex-green outline-none transition-all">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Table Header -->
                <div class="px-4 sm:px-6 py-3 bg-gray-50/50 border-b border-gray-100 flex-shrink-0">
                    <div class="grid grid-cols-4 items-center px-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                        <span class="col-span-2">Kullanıcı / E-Posta</span>
                        <span class="text-center">Durum</span>
                        <span class="text-right">İşlemler</span>
                    </div>
                </div>
                
                <!-- Items Container -->
                <div id="user-list" class="flex-1 overflow-y-auto custom-scrollbar divide-y divide-gray-50 bg-white">
                    <div class="flex flex-col items-center justify-center p-20 text-gray-300">
                        <div class="animate-pulse flex flex-col items-center">
                            <i class="fas fa-circle-notch fa-spin text-3xl mb-4 text-rolex-green"></i>
                            <span class="text-xs font-semibold">Yükleniyor...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Silme Onay Modalı -->
<div id="delete-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-sm text-center transform transition-all scale-95 origin-center animate-fade-in">
        <div class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center text-red-600 mx-auto mb-4">
            <i class="fas fa-trash-alt text-2xl"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-900">Kullanıcıyı Sil?</h3>
        <p class="mt-2 text-xs text-gray-500 leading-relaxed">
            Bu kullanıcıyı silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.
        </p>
        <div id="modal-user-name" class="mt-3 py-2 px-4 bg-gray-50 rounded-lg font-bold text-rolex-green text-sm inline-block"></div>
        <div class="mt-6 flex justify-center gap-3">
            <button id="cancel-delete-btn" class="flex-1 px-4 py-2.5 bg-white border border-gray-200 text-gray-600 text-xs font-bold rounded-xl hover:bg-gray-50 transition-all">İptal</button>
            <button id="confirm-delete-btn" class="flex-1 px-4 py-2.5 bg-red-600 text-white text-xs font-bold rounded-xl hover:bg-red-700 transition-all shadow-lg shadow-red-200">Evet, Sil</button>
        </div>
    </div>
</div>

<div id="toast-container" class="fixed bottom-6 right-6 z-[110] flex flex-col gap-3"></div>

@section Scripts {
    <script src="~/js/user_index.js" asp-append-version="true"></script>
}


