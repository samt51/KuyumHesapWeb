@* Ekstre modal *@

<div id="ekstre-modal" class="hidden fixed inset-0 modal-bg flex items-start justify-center z-50 pt-10">
    <div class="bg-gray-50 rounded-lg shadow-xl w-full max-w-7xl max-h-[90vh] flex flex-col">

        <div class="flex justify-between items-center p-4 ekstre-modal-header rounded-t-lg">
            <h3 class="text-lg font-bold text-gray-700 flex items-center">
                <i class="fas fa-file-invoice-dollar text-gray-500 mr-3"></i>
                Hesap Ekstresi
            </h3>
            <button id="ekstre-modal-close-button" class="text-gray-500 hover:text-red-600 text-2xl transition-colors">&times;</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2 md:gap-3 p-2 md:p-3 border-b bg-white">
            <!-- Müşteri Bilgi Kartı -->
            <div class="ekstre-info-card lg:col-span-1">
                <h4 class="card-title-absolute"><i class="fas fa-user-circle"></i>Müşteri Bilgileri</h4>
                <div class="flex flex-col justify-center h-full">
                    <div class="flex items-baseline gap-2 flex-wrap">
                        <span id="ekstre-hesap-adi" class="font-bold text-gray-800 text-sm md:text-base truncate" title="Hesap Adı"></span>
                        <span id="ekstre-hesap-tipi" class="text-[10px] md:text-xs font-semibold text-blue-600 bg-blue-50 px-1.5 py-0.5 rounded uppercase"></span>
                    </div>
                    <div class="flex items-center gap-3 mt-1 text-[10px] md:text-xs text-gray-500">
                        <span id="ekstre-hesap-id" class="font-mono opacity-70"></span>
                        <span id="ekstre-hesap-telefon" class="hidden md:inline italic"></span>
                    </div>
                </div>
            </div>

            <!-- Bakiye Özeti Kartı -->
            <div class="ekstre-info-card lg:col-span-1">
                <h4 class="card-title-absolute"><i class="fas fa-balance-scale"></i>Bakiye Özeti</h4>
                <div id="ekstre-bakiye-ozeti" class="custom-scrollbar pr-1 ekstre-bakiye-ozeti-v2 overflow-y-auto max-h-[80px]">
                    <!-- Bakiye içeriği JS ile dolacak -->
                </div>
            </div>

            <!-- Tarih Filtreleme & Pozisyon Kartı -->
            <div class="ekstre-info-card lg:col-span-1">
                <h4 class="card-title-absolute"><i class="fas fa-calendar-alt"></i>Filtre & Pozisyon</h4>
                <div class="flex items-stretch gap-0">
                    <input type="date" id="ekstre-baslangic-tarihi" class="block w-full px-2 py-1.5 bg-white border border-gray-300 rounded-l-md shadow-sm text-xs h-[32px] border-r-0">
                    <input type="date" id="ekstre-bitis-tarihi" class="block w-full px-2 py-1.5 bg-white border border-gray-300 shadow-sm text-xs h-[32px] rounded-none">
                    <button id="ekstre-getir-button" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-1 px-3 rounded-r-md text-xs h-[32px] border border-blue-600 flex items-center justify-center">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
                <div class="mt-1.5 flex justify-between items-center bg-gray-50 p-1 px-2 rounded border border-gray-100">
                    <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Net Pozisyon:</span>
                    <span id="ekstre-has-pozisyon" class="text-xs font-bold text-gray-700"></span>
                </div>
            </div>
        </div>

        <div id="ekstre-content" class="p-2 md:p-3 overflow-y-auto bg-white rounded-b-lg flex-grow">
            <!-- Ekstre içeriği JS ile dolacak -->
        </div>
    </div>
</div>
