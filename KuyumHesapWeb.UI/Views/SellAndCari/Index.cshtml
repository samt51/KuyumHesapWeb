@using KuyumHesapWeb.Core.Commond.Models.Dtos
@model GetAllAccountResponseDto
@{
    ViewData["Title"] = "Index";
    var noLayout = Context.Request.Query["noLayout"].ToString() == "1";
    Layout = noLayout ? "~/Views/Shared/_IframeLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
}



@section Styles {
    <link rel="stylesheet" href="~/css/satisVeCari.css" asp-append-version="true" />
}
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@await Html.PartialAsync("_Header")

@await Html.PartialAsync("_ConfirmationModal")
@await Html.PartialAsync("_ToastModal")
@await Html.PartialAsync("_LoadingOverlay")
@await Html.PartialAsync("_EkstreModal")
@await Html.PartialAsync("_FisListModal")
@await Html.PartialAsync("_UrunFormTemplate")

@section Scripts {
    <script>
         (function() {
            // appsettings içindeki ApiAddress değeri buraya gömülür
            var api = '@(Configuration["LocalAddress"] ?? "")';
            // sondaki slash varsa temizle
            api = api ? api.replace(/\/$/, '') : '';
            window.API_BASE_URL = api;
            // fallback varsa local path kullan
            window.CURE_GET_LATEST_URL = api ? api + '/Cure/GetLatestCure' : '/Cure/GetLatestCure';
        })();
    </script>

    <script src="~/js/satisVeCari.js" asp-append-version="true"></script>
}












