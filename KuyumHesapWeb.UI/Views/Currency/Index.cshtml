
@{
    ViewData["Title"] = "Index";
    var noLayout = Context.Request.Query["noLayout"] == "1";
    Layout = noLayout ? "~/Views/Shared/_IframeLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/doviz_index.css" />
}
 

<div class="flex flex-col md:flex-row gap-5 w-full h-[calc(100vh-2.5rem)]">
    <div class="flex flex-col flex-[3]">
        <div class="panel bg-white rounded-lg shadow-sm border border-rolex-green p-6 flex flex-col flex-grow min-h-0">
            <h2 class="text-xl font-semibold text-gray-800 mb-6 pb-2 border-b border-rolex-green flex-shrink-0">Döviz Tanımlama</h2>
            <div class="flex-grow overflow-y-auto pr-4 -mr-4">
                <form id="item-form" class="space-y-5">
                    <input type="hidden" id="id">

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="relative form-group">
                            <input type="text" id="dovizKodu" required maxlength="5" class="form-input mt-1 block w-full p-2.5 border border-rolex-green rounded-md shadow-sm focus:border-black focus:ring-0 peer" placeholder=" ">
                            <label for="dovizKodu" class="form-label">Döviz Kodu</label>
                        </div>
                        <div class="relative form-group">
                            <input type="text" id="dovizAdi" required class="form-input mt-1 block w-full p-2.5 border border-rolex-green rounded-md shadow-sm focus:border-black focus:ring-0 peer" placeholder=" ">
                            <label for="dovizAdi" class="form-label">Döviz Adı</label>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="relative form-group">
                            <input type="text" id="sembol" maxlength="5" class="form-input mt-1 block w-full p-2.5 border border-rolex-green rounded-md shadow-sm focus:border-black focus:ring-0 peer" placeholder=" ">
                            <label for="sembol" class="form-label">Sembol</label>
                        </div>
                        <div class="relative form-group">
                            <input type="text" id="ulke" class="form-input bg-gray-100 mt-1 block w-full p-2.5 border border-rolex-green rounded-md shadow-sm focus:border-black focus:ring-0 peer" placeholder=" " readonly>
                            <label for="ulke" class="form-label">Ülke</label>
                        </div>
                    </div>

                    <div class="relative form-group">
                        <select id="metaKodu" class="form-input mt-1 block w-full p-2.5 border border-rolex-green rounded-md shadow-sm focus:border-black focus:ring-0 peer bg-white">
                            <option value="">Meta Kodu Seçin...</option>
                        </select>
                        <label for="metaKodu" class="form-label">Meta Kodu</label>
                    </div>



                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 pt-2">
                        <div class="border border-rolex-green rounded-md p-3"><div class="flex items-center justify-between"><label class="block text-sm font-medium text-gray-700">Aktif</label><label class="toggle-switch"><input id="aktif" type="checkbox" checked><span class="toggle-slider"></span></label></div></div>
                        <div class="border border-rolex-green rounded-md p-3"><div class="flex items-center justify-between"><label class="block text-sm font-medium text-gray-700">Bilanço P.B.</label><label class="toggle-switch"><input id="bilancoParabirimi" type="checkbox"><span class="toggle-slider"></span></label></div></div>
                        <div class="border border-rolex-green rounded-md p-3"><div class="flex items-center justify-between"><label class="block text-sm font-medium text-gray-700">Ülke P.B.</label><label class="toggle-switch"><input id="ulkeParabirimi" type="checkbox"><span class="toggle-slider"></span></label></div></div>
                    </div>
                </form>
            </div>
            <div class="flex justify-end gap-4 pt-4 mt-4 border-t border-gray-200 flex-shrink-0">
                <div id="add-mode-buttons" class="flex gap-4">
                    <button type="button" id="vazgec-btn" class="px-8 py-2 bg-secondary text-white font-semibold rounded-lg hover:bg-opacity-90 shadow-sm">VAZGEÇ</button>
                    <button type="submit" form="item-form" class="px-8 py-2 bg-success text-white font-semibold rounded-lg hover:bg-opacity-90 shadow-sm">EKLE</button>
                </div>
                <div id="edit-mode-buttons" class="hidden flex gap-4">
                    <button type="button" id="sil-btn" class="px-8 py-2 bg-danger text-white font-semibold rounded-lg hover:bg-opacity-90 shadow-sm">SİL</button>
                    <button type="button" id="vazgec-guncelle-btn" class="px-8 py-2 bg-secondary text-white font-semibold rounded-lg hover:bg-opacity-90 shadow-sm">VAZGEÇ</button>
                    <button type="submit" form="item-form" class="px-8 py-2 bg-rolex-green text-white font-semibold rounded-lg hover:bg-opacity-90 shadow-sm">GÜNCELLE</button>
                </div>
            </div>
        </div>
    </div>
    <div class="flex flex-col flex-[2]">
        <div class="panel bg-white rounded-lg shadow-sm border border-rolex-green p-4 flex flex-col flex-grow min-h-0">
            <h2 class="text-xl font-semibold text-gray-800 mb-4 pb-2 border-b border-rolex-green flex-shrink-0">Döviz Listesi</h2>
            <div class="flex-grow overflow-y-auto">
                <div class="grid grid-cols-4 text-sm font-semibold text-gray-500 px-3 py-2 border-b sticky top-0 bg-white z-10"><span>Kod</span><span>Ad</span><span class="text-right">Alış</span><span class="text-right">Satış</span></div>
                <div id="item-list" class="space-y-1"></div>
            </div>
        </div>
    </div>
</div>
<div id="toast-container" class="fixed top-5 left-1/2 -translate-x-1/2 z-50 flex flex-col items-center gap-2"></div>
 

@section Scripts {
    <script>
        window.CURE_GET_LATEST_URL = '@Url.Action("GetLatestCure", "Cure")';
    </script>

    <script src="~/js/doviz_index.js" asp-append-version="true"></script>
}
