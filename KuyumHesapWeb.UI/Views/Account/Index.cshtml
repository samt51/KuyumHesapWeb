@using KuyumHesapWeb.Core.Feature.AccountFeature.Queries.GetAll
@model List<GetAllAccountQueryResponse>
@{
    var noLayout = Context.Request.Query["noLayout"].ToString() == "1";
    Layout = noLayout ? "~/Views/Shared/_IframeLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Hesap Tanımlama";
}

@section Styles {
    <link rel="stylesheet" href="~/css/hesaplar_index.css" asp-append-version="true" />
}

<div class="h-screen flex flex-col bg-slate-50 overflow-hidden font-sans">
    <!-- Top Header Bar -->
    <div class="flex-shrink-0 bg-white border-b border-gray-200 px-6 py-3 flex justify-between items-center shadow-sm relative z-20">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-rolex-green/10 rounded-xl flex items-center justify-center text-rolex-green">
                <i class="fas fa-users text-xl"></i>
            </div>
            <div class="hidden sm:block">
                <h1 class="text-lg font-bold text-gray-800 leading-tight">Hesap Tanımlama</h1>
                <p class="text-[10px] text-gray-500 font-medium uppercase tracking-wider">Tanımlamalar / Cari Yönetimi</p>
            </div>
        </div>
        <div class="flex items-center gap-2">
            <span id="list-count" class="bg-gray-100 text-gray-600 px-3 py-1 rounded-full text-[11px] font-bold border border-gray-200">0 Kayıt</span>
        </div>
    </div>

    <!-- Main Content Area: Responsive Stack -->
    <div class="flex-1 overflow-y-auto lg:overflow-hidden p-3 sm:p-4 min-h-0 bg-slate-50 custom-scrollbar">
        <div class="flex flex-col lg:flex-row gap-4 h-full">
            
            <!-- Left: Form Section -->
            <div class="lg:flex-[3] bg-white border border-gray-200 rounded-2xl shadow-sm flex flex-col min-h-[500px] lg:min-h-0 overflow-hidden">
                <!-- Tabs Header -->
                <div class="bg-gray-50/50 border-b border-gray-100 px-6 pt-3 flex-shrink-0">
                    <nav class="flex gap-6" aria-label="Tabs">
                        <button class="tab-button py-3 px-1 border-b-2 font-bold text-xs transition-all active border-rolex-green text-rolex-green" data-tab="temel">
                            TEMEL BİLGİLER
                        </button>
                        <button class="tab-button py-3 px-1 border-b-2 font-bold text-xs transition-all text-gray-400 border-transparent hover:text-gray-600" data-tab="adres">
                            ADRES BİLGİLERİ
                        </button>
                    </nav>
                </div>

                <!-- Form Content -->
                <div class="flex-1 overflow-y-auto custom-scrollbar p-6 sm:p-8">
                    <form id="item-form" class="h-full">
                        <input type="hidden" id="hesapID">

                        <!-- Tab: Temel Bilgiler -->
                        <div id="tab-temel" class="tab-content active space-y-6">
                            <div class="relative form-group group">
                                <input type="text" id="hesapAdi" required class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                                <label for="hesapAdi" class="form-label">Hesap Adı</label>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="relative form-group group">
                                    <select id="hesapTipiID" required class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none">
                                        <option value="" disabled selected>Seçiniz</option>
                                    </select>
                                    <label for="hesapTipiID" class="form-label">Hesap Tipi</label>
                                </div>
                                <div class="relative form-group group">
                                    <select id="musteriTipi" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none">
                                        <option value="Bireysel">Bireysel</option>
                                        <option value="Kurumsal">Kurumsal</option>
                                        <option value="Sistem">Sistem</option>
                                    </select>
                                    <label for="musteriTipi" class="form-label">Müşteri Tipi</label>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="relative form-group group">
                                    <input type="tel" id="cepTelefonu" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                                    <label for="cepTelefonu" class="form-label">Cep Telefonu</label>
                                </div>
                                <div class="relative form-group group">
                                    <input type="email" id="mail" autocomplete="off" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                                    <label for="mail" class="form-label">E-Posta</label>
                                </div>
                            </div>

                            <div id="bireysel-fields" class="relative form-group group">
                                <input type="text" id="tcKimlikNo" maxlength="11" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                                <label for="tcKimlikNo" id="kimlik-pasaport-label" class="form-label">TC Kimlik No</label>
                            </div>

                            <div id="kurumsal-fields" class="hidden grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="relative form-group group">
                                    <input type="text" id="vergiDairesi" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                                    <label for="vergiDairesi" class="form-label">Vergi Dairesi</label>
                                </div>
                                <div class="relative form-group group">
                                    <input type="text" id="vergiNo" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                                    <label for="vergiNo" class="form-label">Vergi No</label>
                                </div>
                            </div>

                            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-2xl border border-gray-100">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-xl bg-white flex items-center justify-center text-rolex-green shadow-sm">
                                        <i class="fas fa-toggle-on text-sm"></i>
                                    </div>
                                    <span class="text-xs font-bold text-gray-700">Hesap Durumu (Aktif)</span>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" id="aktif" class="sr-only peer" checked>
                                    <div class="w-11 h-6 bg-gray-200 rounded-full peer peer-focus:ring-2 peer-focus:ring-rolex-green/20 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-rolex-green"></div>
                                </label>
                            </div>
                        </div>

                        <!-- Tab: Adres Bilgileri -->
                        <div id="tab-adres" class="tab-content hidden space-y-6">
                            <div class="relative form-group group">
                                <select id="ulke" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none">
                                    <option value="Türkiye" selected>Türkiye</option>
                                    <option value="Diğer">Diğer</option>
                                </select>
                                <label for="ulke" class="form-label">Ülke</label>
                            </div>
                            
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="relative form-group group">
                                    <input type="text" id="sehir" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                                    <label for="sehir" class="form-label">Şehir</label>
                                </div>
                                <div class="relative form-group group">
                                    <input type="text" id="ilce" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                                    <label for="ilce" class="form-label">İlçe</label>
                                </div>
                            </div>

                            <div class="relative form-group group">
                                <input type="text" id="mahalle" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" ">
                                <label for="mahalle" class="form-label">Mahalle</label>
                            </div>

                            <div class="relative form-group group">
                                <textarea id="fullAdres" rows="3" class="form-input block w-full px-4 py-4 bg-gray-50 border-2 border-transparent rounded-xl text-sm text-gray-900 font-medium transition-all focus:bg-white focus:border-rolex-green focus:ring-4 focus:ring-rolex-green/5 outline-none peer appearance-none" placeholder=" "></textarea>
                                <label for="fullAdres" class="form-label">Açık Adres</label>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Bottom Actions -->
                <div class="p-4 sm:p-6 border-t border-gray-100 bg-gray-50/50 rounded-b-2xl">
                    <div id="add-mode-buttons" class="flex justify-end gap-2">
                        <button type="button" id="vazgec-btn" class="px-4 sm:px-8 py-2.5 bg-white border border-gray-200 text-gray-600 text-[10px] sm:text-xs font-bold rounded-xl hover:bg-gray-100 transition-all active:scale-[0.98]">
                            VAZGEÇ
                        </button>
                        <button type="submit" form="item-form" class="px-6 sm:px-10 py-2.5 bg-rolex-green text-white text-[10px] sm:text-xs font-bold rounded-xl hover:bg-opacity-90 hover:shadow-lg hover:shadow-rolex-green/20 transition-all active:scale-[0.98] flex items-center justify-center gap-2">
                            <i class="fas fa-plus-circle"></i>
                            <span>EKLE</span>
                        </button>
                    </div>

                    <div id="edit-mode-buttons" class="hidden flex justify-end gap-2">
                        <button type="button" id="sil-btn" class="px-4 py-2.5 bg-red-50 text-red-600 text-[10px] sm:text-xs font-bold rounded-xl hover:bg-red-100 transition-all active:scale-[0.98] flex items-center justify-center gap-2">
                            <i class="fas fa-trash-alt"></i>
                            <span class="hidden sm:inline">SİL</span>
                        </button>
                        <button type="button" id="vazgec-guncelle-btn" class="px-4 py-2.5 bg-white border border-gray-200 text-gray-600 text-[10px] sm:text-xs font-bold rounded-xl hover:bg-gray-100 transition-all active:scale-[0.98]">
                            VAZGEÇ
                        </button>
                        <button type="submit" form="item-form" class="px-6 sm:px-10 py-2.5 bg-rolex-green text-white text-[10px] sm:text-xs font-bold rounded-xl hover:bg-opacity-90 hover:shadow-lg hover:shadow-rolex-green/20 transition-all active:scale-[0.98] flex items-center justify-center gap-2">
                            <i class="fas fa-save text-sm"></i>
                            <span>GÜNCELLE</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Right: List Section -->
            <div class="lg:flex-[2] bg-white border border-gray-200 rounded-2xl flex flex-col min-h-[400px] lg:min-h-0 shadow-sm relative overflow-hidden">
                <!-- List Header -->
                <div class="p-4 sm:p-6 border-b border-gray-100 space-y-4">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                        <h3 class="text-sm font-bold text-gray-900">Hesap Listesi</h3>
                        <div class="flex gap-2">
                            <div class="relative">
                                <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-[10px]"></i>
                                <input type="text" id="arama-input" placeholder="Hesap Ara..." class="pl-8 pr-3 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-[10px] focus:ring-2 focus:ring-rolex-green/10 focus:border-rolex-green outline-none transition-all w-32 sm:w-40">
                            </div>
                            <select id="hesap-tipi-filtre" class="px-2 py-1.5 bg-gray-50 border border-gray-200 rounded-lg text-[10px] focus:ring-2 focus:ring-rolex-green/10 focus:border-rolex-green outline-none transition-all w-28 sm:w-32">
                                <option value="">Tüm Tipler</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Table Header -->
                <div class="px-4 sm:px-6 py-3 bg-gray-50/50 border-b border-gray-100 flex-shrink-0">
                    <div class="grid grid-cols-4 items-center px-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                        <span class="col-span-2">Hesap Adı</span>
                        <span class="text-center">Tip</span>
                        <span class="text-right">Durum</span>
                    </div>
                </div>
                
                <!-- Items Container -->
                <div id="item-list" class="flex-1 overflow-y-auto custom-scrollbar divide-y divide-gray-50">
                    <!-- JS will populate here -->
                    <div class="flex flex-col items-center justify-center p-20 text-gray-300">
                        <div class="animate-pulse flex flex-col items-center">
                            <i class="fas fa-circle-notch fa-spin text-3xl mb-4"></i>
                            <span class="text-xs font-semibold">Yükleniyor...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Silme Onay Modalı -->
<div id="delete-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-sm text-center transform transition-all scale-95 origin-center">
        <div class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center text-red-600 mx-auto mb-4">
            <i class="fas fa-trash-alt text-2xl"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-900">Hesabı Sil?</h3>
        <p class="mt-2 text-xs text-gray-500 leading-relaxed">
            Bu hesabı silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.
        </p>
        <div id="modal-item-name" class="mt-3 py-2 px-4 bg-gray-50 rounded-lg font-bold text-rolex-green text-sm inline-block"></div>
        <div class="mt-6 flex justify-center gap-3">
            <button id="cancel-delete-btn" class="flex-1 px-4 py-2.5 bg-white border border-gray-200 text-gray-600 text-xs font-bold rounded-xl hover:bg-gray-50 transition-all">İptal</button>
            <button id="confirm-delete-btn" class="flex-1 px-4 py-2.5 bg-red-600 text-white text-xs font-bold rounded-xl hover:bg-red-700 transition-all shadow-lg shadow-red-200">Evet, Sil</button>
        </div>
    </div>
</div>

<div id="toast-container" class="fixed bottom-6 right-6 z-[110] flex flex-col gap-3"></div>

@section Scripts {
    <script src="~/js/hesaplar_index.js" asp-append-version="true"></script>
}
