@{
    Layout = null;
}


<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ana Menü | KuyumHesap</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/slim-select@1.27.0/dist/slimselect.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/home_index.css" />
    @inject Microsoft.Extensions.Configuration.IConfiguration Configuration

    <script>
        (function() {
            // appsettings içindeki ApiAddress değeri buraya gömülür
            var api = '@(Configuration["LocalAddress"] ?? "")';
            // sondaki slash varsa temizle
            api = api ? api.replace(/\/$/, '') : '';
            window.API_BASE_URL = api;
            // fallback varsa local path kullan
            window.CURE_GET_LATEST_URL = api ? api + '/Cure/GetLatestCure' : '/Cure/GetLatestCure';
        })();
    </script>
    @RenderSection("Styles", required: false)

</head>
<body class="bg-gray-100 overflow-hidden text-sm">

    <!-- Mobile Overlay -->
    <div id="mobile-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 transition-opacity duration-300 ease-in-out opacity-0 pointer-events-none"></div>

    <nav id="sidebar-menu" class="hidden md:flex fixed top-0 left-0 h-full w-16 bg-white text-gray-800 shadow-xl z-50 transition-all duration-300 ease-in-out flex-col group">
        <div class="p-3 flex items-center justify-start h-16 flex-shrink-0">
            <button id="sidebar-toggle" class="text-gray-700 focus:outline-none pl-2 flex-shrink-0 transition-colors hover:text-green-700">
                <i class="fas fa-bars text-xl"></i>
            </button>
            <div class="relative ml-4 flex-grow sidebar-text">
                <span class="font-bold text-lg text-gray-800 tracking-wide">KuyumHesap</span>
            </div>
        </div>
        <div id="menu-links-container" data-authorized-menu-url="@Url.Action("GetAuthorizedForCurrentUser", "MenuSettings")" class="py-2 overflow-y-auto overflow-x-hidden flex-grow">
            <!-- ARAMA ALANI EKLENDİ (Dar modda simge, genişte input) -->
            <div class="sidebar-link-container">
                <div class="relative flex items-center px-5 py-2 text-gray-700 transition-colors overflow-hidden">
                    <i class="fas fa-search w-6 text-center text-xl text-gray-500 flex-shrink-0"></i>
                    <div class="ml-3 flex-grow sidebar-text">
                        <input type="text" id="sidebar-search" placeholder="Menüde Ara..." class="w-full bg-gray-100 border border-gray-200 rounded-md py-1.5 px-3 text-xs focus:outline-none focus:ring-1 focus:ring-green-700">
                    </div>
                </div>
            </div>
            <div class="sidebar-link-container">
                <a href="javascript:void(0);" onclick="openTab('@Url.Action("IndexDashboard", "Dashboard")', 'Ana Sayfa')" class="sidebar-link flex items-center px-5 py-2.5 text-gray-700 transition-colors">
                    <i class="fas fa-home w-6 text-center text-xl text-gray-500"></i>
                    <span class="ml-3 font-semibold text-sm sidebar-text whitespace-nowrap">Ana Sayfa</span>
                </a>
            </div>

            <div class="sidebar-link-container">
                <a href="javascript:void(0);" onclick="openTab('@Url.Action("Index", "SellAndCari")', 'Satış ve Cari')" class="sidebar-link flex items-center px-5 py-2.5 text-gray-700 transition-colors">
                    <i class="fas fa-shopping-cart w-6 text-center text-xl text-gray-500"></i>
                    <span class="ml-3 font-semibold text-sm sidebar-text whitespace-nowrap">Satış ve Cari</span>
                </a>
            </div>

            <div class="sidebar-link-container">
                <div class="sidebar-link flex items-center px-5 py-2.5 text-gray-700 transition-colors cursor-pointer">
                    <i class="fas fa-chart-line w-6 text-center text-xl text-gray-500"></i>
                    <span class="ml-3 font-semibold text-sm sidebar-text whitespace-nowrap">Cari Raporlar</span>
                    <i class="fas fa-chevron-right ml-auto sidebar-text chevron-icon text-xs"></i>
                </div>
                <div class="submenu hidden">
                    <a href="javascript:void(0);" onclick="openTab('@Url.Action("KasaRaporu", "Raporlar")', 'Kasa Raporu')" class="flex items-center px-4 py-2.5 text-xs font-medium text-gray-600 hover:bg-gray-50 hover:text-green-700 transition-colors border-l-2 border-transparent hover:border-green-600 group">
                        <i class="fas fa-wallet w-5 text-center text-gray-400 mr-2 group-hover:text-green-600 transition-colors"></i><span>Kasa Raporu</span>
                    </a>
                    <a href="javascript:void(0);" onclick="openTab('@Url.Action("NakitGirisCikis", "Raporlar")', 'Nakit Giriş Çıkış Raporu')" class="flex items-center px-4 py-2.5 text-xs font-medium text-gray-600 hover:bg-gray-50 hover:text-green-700 transition-colors border-l-2 border-transparent hover:border-green-600 group">
                        <i class="fas fa-exchange-alt w-5 text-center text-gray-400 mr-2 group-hover:text-green-600 transition-colors"></i><span>Nakit Giriş Çıkış Raporu</span>
                    </a>
                </div>
            </div>

            <div class="sidebar-link-container">
                <div class="sidebar-link flex items-center px-5 py-2.5 text-gray-700 transition-colors cursor-pointer">
                    <i class="fas fa-sitemap w-6 text-center text-xl text-gray-500"></i>
                    <span class="ml-3 font-semibold text-sm sidebar-text whitespace-nowrap">Tanımlamalar</span>
                    <i class="fas fa-chevron-right ml-auto sidebar-text chevron-icon text-xs"></i>
                </div>
                <div class="submenu hidden">
                    <a href="javascript:void(0);" onclick="openTab('@Url.Action("Index", "Account")', 'Hesap Tanımlama')" class="flex items-center px-4 py-2 text-xs font-medium text-gray-600 hover:bg-gray-50 hover:text-green-700 transition-colors border-l-2 border-transparent hover:border-green-600 group">
                        <i class="fas fa-tags w-5 text-center text-gray-400 mr-2 group-hover:text-green-600 transition-colors"></i><span>Hesap Tanımlama</span>
                    </a>
                    <a href="javascript:void(0);" onclick="openTab('@Url.Action("Index", "AccountType")', 'Hesap Tipleri Tanımlama')" class="flex items-center px-4 py-2 text-xs font-medium text-gray-600 hover:bg-gray-50 hover:text-green-700 transition-colors border-l-2 border-transparent hover:border-green-600 group">
                        <i class="fas fa-tags w-5 text-center text-gray-400 mr-2 group-hover:text-green-600 transition-colors"></i><span>Hesap Tipleri Tanımlama</span>
                    </a>
                    <a href="javascript:void(0);" onclick="openTab('@Url.Action("Index", "Currency")', 'Döviz Tanımlama')" class="flex items-center px-4 py-2 text-xs font-medium text-gray-600 hover:bg-gray-50 hover:text-green-700 transition-colors border-l-2 border-transparent hover:border-green-600 group">
                        <i class="fas fa-coins w-5 text-center text-gray-400 mr-2 group-hover:text-green-600 transition-colors"></i><span>Döviz Tanımlama</span>
                    </a>
                    <a href="javascript:void(0);" onclick="openTab('@Url.Action("Index", "StockGroup")', 'Stok Grubu Tanımlama')" class="flex items-center px-4 py-2 text-xs font-medium text-gray-600 hover:bg-gray-50 hover:text-green-700 transition-colors border-l-2 border-transparent hover:border-green-600 group">
                        <i class="fas fa-layer-group w-5 text-center text-gray-400 mr-2 group-hover:text-green-600 transition-colors"></i><span>Stok Grubu Tanımlama</span>
                    </a>
                    <a href="javascript:void(0);" onclick="openTab('@Url.Action("Index", "StockType")', 'Stok Tipleri Tanımlama')" class="flex items-center px-4 py-2 text-xs font-medium text-gray-600 hover:bg-gray-50 hover:text-green-700 transition-colors border-l-2 border-transparent hover:border-green-600 group">
                        <i class="fas fa-cubes w-5 text-center text-gray-400 mr-2 group-hover:text-green-600 transition-colors"></i><span>Stok Tipleri Tanımlama</span>
                    </a>
                    <a href="javascript:void(0);" onclick="openTab('@Url.Action("Index", "Stock")', 'Stok Tanımlama')" class="flex items-center px-4 py-2 text-xs font-medium text-gray-600 hover:bg-gray-50 hover:text-green-700 transition-colors border-l-2 border-transparent hover:border-green-600 group">
                        <i class="fas fa-box w-5 text-center text-gray-400 mr-2 group-hover:text-green-600 transition-colors"></i><span>Stok Tanımlama</span>
                    </a>
                    <a href="javascript:void(0);" onclick="openTab('@Url.Action("Index", "ProductType")', 'Ürün Tipi Tanımlama')" class="flex items-center px-4 py-2 text-xs font-medium text-gray-600 hover:bg-gray-50 hover:text-green-700 transition-colors border-l-2 border-transparent hover:border-green-600 group">
                        <i class="fas fa-gem w-5 text-center text-gray-400 mr-2 group-hover:text-green-600 transition-colors"></i><span>Ürün Tipi Tanımlama</span>
                    </a>
                    <a href="javascript:void(0);" onclick="openTab('@Url.Action("Index", "User")', 'Kullanıcı Tanımlama')" class="flex items-center px-4 py-2 text-xs font-medium text-gray-600 hover:bg-gray-50 hover:text-green-700 transition-colors border-l-2 border-transparent hover:border-green-600 group">
                        <i class="fas fa-users-cog w-5 text-center text-gray-400 mr-2 group-hover:text-green-600 transition-colors"></i><span>Kullanıcı Tanımlama</span>
                    </a>
                </div>
            </div>
            <!-- Eski Sabit Ayarlar menüsü tamamen kaldırılarak Yönetim Paneline / Dinamik Veritabanı yapısına devredildi -->
        </div>
        <div class="mt-auto flex-shrink-0">
            <div class="sidebar-link-container">
                <a href="#" class="sidebar-link flex items-center px-5 py-2.5 text-gray-700 transition-colors">
                    <i class="fas fa-user-circle w-6 text-center text-xl text-gray-500"></i>
                    <span id="display-username" class="ml-3 font-semibold text-sm sidebar-text whitespace-nowrap">Kullanıcı</span>
                </a>
            </div>
            <div class="sidebar-link-container">
                <a id="logout-button" href="#" class="sidebar-link flex items-center px-5 py-2.5 text-gray-700 transition-colors hover:text-red-600">
                    <i class="fas fa-sign-out-alt w-6 text-center text-xl text-gray-500"></i>
                    <span class="ml-3 font-semibold text-sm sidebar-text whitespace-nowrap">Çıkış Yap</span>
                </a>
            </div>
        </div>
    </nav>

    <div id="submenu-flyout" class="fixed top-0 h-full z-30 bg-white shadow-lg rolex-green-border transition-opacity duration-200 ease-in-out opacity-0 pointer-events-none" style="width: 220px;"></div>

    <main id="main-content" data-login-url="@Url.Action("Login", "Auth")" data-dashboard-url="@Url.Action("IndexDashboard", "Dashboard")" class="h-screen flex flex-col transition-all duration-300 ease-in-out w-full pl-0 md:pl-16">
        <div class="flex items-center w-full bg-gray-100 border-b border-gray-300" style="height: 40px;">
            <div id="mobile-top-hamburger" class="md:hidden flex-shrink-0 flex items-center justify-center px-4 h-full cursor-pointer text-gray-600 hover:text-green-700 border-r border-gray-300 bg-white transition-colors shadow-sm relative z-40">
                <i class="fas fa-bars text-lg"></i>
            </div>
            <div id="tabs-container" class="flex-grow flex-shrink-0 h-full overflow-x-auto hide-scrollbar flex items-end"></div>
        </div>
        <div id="native-content" class="flex-1 min-h-0 relative overflow-y-auto">
            @RenderBody()
        </div>
        <div id="content-frames" class="flex-1 min-h-0 relative overflow-hidden hidden"></div>
    </main>
    <script src="~/js/common.js" asp-append-version="true"></script>
    <script src="~/js/permission_guard.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
    <script src="~/js/home_index.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/slim-select@1.27.0/dist/slimselect.min.js"></script>
</body>
</html>


